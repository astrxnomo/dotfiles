{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#69FF94",
          "style": "plain",
          "template": "\u276f",
          "type": "text"
        },
        {
          "foreground": "#56B6C2",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#D0666F",
          "options": {
            "branch_icon": "",
            "fetch_status": false
          },
          "style": "plain",
          "template": "<#5FAAE8>git:(</>{{ .HEAD }}<#5FAAE8>)</> ",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
