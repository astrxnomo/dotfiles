{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#C792EA",
          "style": "plain",
          "template": "\u276f",
          "type": "text"
        },
        {
          "foreground": "#B084F5",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#E0A6E8",
          "options": {
            "branch_icon": "",
            "fetch_status": false
          },
          "style": "plain",
          "template": "<#9D65E0>git:(</>{{ .HEAD }}<#9D65E0>)</> ",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
